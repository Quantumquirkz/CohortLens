# Copy to .env on the server or inject via your orchestrator (Kubernetes, ECS, etc.).
# Never commit real secrets.

DATABASE_URL=postgresql://user:password@db-host:5432/cohortlens
REDIS_URL=redis://redis-host:6379/0
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/1

WEB3_RPC=https://eth.llamarpc.com
CHAINS_JSON=
DEFAULT_CHAIN=polygon

IPFS_API_URL=https://ipfs.example.com:5001

REQUIRE_WALLET_AUTH=true
CORS_ORIGINS=https://app.example.com

PROMETHEUS_ENABLED=true

# Optional error tracking (leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

LOG_LEVEL=INFO
GRAPHQL_ENABLED=true
GRAPHQL_INTROSPECTION=false
GRAPHQL_MAX_DEPTH=8
GRAPHQL_MAX_ALIASES=30

ORACLE_OWNER_PRIVATE_KEY=
ORACLE_REQUESTER_PRIVATE_KEY=
