DATABASE_URL=postgresql://cohortlens:cohortlens@localhost:5432/cohortlens
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Subgraph GraphQL (Graph Node local: puerto 8020 en el host; dentro de Docker: http://graph-node:8000/...)
SUBGRAPH_URL=http://127.0.0.1:8020/subgraphs/name/cohortlens/aave-v3

# Sepolia — CohortOracle
SEPOLIA_RPC_URL=https://rpc.sepolia.org
COHORT_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
COHORT_LENS_ID=0

# Firma requestPrediction (API). Debe tener ETH en Sepolia.
ORACLE_REQUESTER_PRIVATE_KEY=

# Firma fulfillRequest (solo owner del contrato). Solo en Celery worker.
ORACLE_OWNER_PRIVATE_KEY=

ORACLE_FROM_BLOCK=0
ORACLE_SCAN_CHUNK_BLOCKS=2000
