DATABASE_URL=postgresql://cohortlens:cohortlens@localhost:5432/cohortlens
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Subgraph GraphQL (local Graph Node: host port 8020; in Docker: http://graph-node:8000/...)
SUBGRAPH_URL=http://127.0.0.1:8020/subgraphs/name/cohortlens/aave-v3

# Sepolia — CohortOracle
SEPOLIA_RPC_URL=https://rpc.sepolia.org
COHORT_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
COHORT_LENS_ID=0

# Signs requestPrediction (API). Needs ETH on Sepolia. Not used if REQUIRE_LENS_PAYMENT_FOR_DISCOVER=true.
ORACLE_REQUESTER_PRIVATE_KEY=

# Phase 7 — user-paid discover (POST /cohorts/discover with payment_tx_hash) or stake checks on upload
REQUIRE_LENS_PAYMENT_FOR_DISCOVER=false
REQUIRE_STAKE_FOR_UPLOAD=false
# CHAINS_JSON must include lens_token_address and staking_address for stake checks, e.g.
# {"polygon":{"subgraph_url":"...","rpc_url":"...","cohort_oracle_address":"0x...","cohort_registry_address":"0x...","lens_token_address":"0x...","staking_address":"0x..."}}

# Signs fulfillRequest (contract owner only). Celery worker only.
ORACLE_OWNER_PRIVATE_KEY=

ORACLE_FROM_BLOCK=0
ORACLE_SCAN_CHUNK_BLOCKS=2000

# Model marketplace (IPFS + CohortRegistry on Sepolia)
IPFS_API_URL=http://127.0.0.1:5001
COHORT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_UPLOADER_PRIVATE_KEY=
MODEL_CACHE_DIR=/tmp/cohortlens_models
MAX_UPLOAD_BYTES=52428800
REQUIRE_WALLET_AUTH=false

# CORS (comma-separated origins). Production: https://your-app.example
CORS_ORIGINS=http://localhost:3000

# Optional: Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=INFO
GRAPHQL_ENABLED=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_MAX_DEPTH=8
GRAPHQL_MAX_ALIASES=30

# Multi-chain (optional). If empty, SUBGRAPH_URL is used as chain "polygon".
# CHAINS_JSON={"polygon":{"subgraph_url":"http://127.0.0.1:8020/subgraphs/name/cohortlens/aave-v3","rpc_url":"https://rpc.sepolia.org","cohort_oracle_address":"","cohort_registry_address":""}}
CHAINS_JSON=
ORACLE_SCAN_CHAIN=polygon
COHORT_CACHE_TTL_SECONDS=3600
PROMETHEUS_ENABLED=true
ENABLE_ZK_PROOF_FOR_ONNX=false
EZKL_BINARY=ezkl
AKASH_CLI_ENABLED=false

# Hugging Face Hub (optional; link/sync lenses — chain + IPFS remain source of truth)
# HF_TOKEN=
HF_ALLOWED_REPOS=*

# PostgREST JWT (optional; must match postgrest service PGRST_JWT_SECRET)
# POSTGREST_JWT_SECRET=

# Gradio lab calls predict with this header when REQUIRE_WALLET_AUTH=true
# GRADIO_INTERNAL_API_KEY=
