DATABASE_URL=postgresql://cohortlens:cohortlens@localhost:5432/cohortlens
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Subgraph GraphQL (local Graph Node: host port 8020; in Docker: http://graph-node:8000/...)
SUBGRAPH_URL=http://127.0.0.1:8020/subgraphs/name/cohortlens/aave-v3

# Sepolia — CohortOracle
SEPOLIA_RPC_URL=https://rpc.sepolia.org
COHORT_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
COHORT_LENS_ID=0

# Signs requestPrediction (API). Needs ETH on Sepolia.
ORACLE_REQUESTER_PRIVATE_KEY=

# Signs fulfillRequest (contract owner only). Celery worker only.
ORACLE_OWNER_PRIVATE_KEY=

ORACLE_FROM_BLOCK=0
ORACLE_SCAN_CHUNK_BLOCKS=2000

# Model marketplace (IPFS + CohortRegistry on Sepolia)
IPFS_API_URL=http://127.0.0.1:5001
COHORT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_UPLOADER_PRIVATE_KEY=
MODEL_CACHE_DIR=/tmp/cohortlens_models
MAX_UPLOAD_BYTES=52428800
REQUIRE_WALLET_AUTH=false

# Multi-chain (optional). If empty, SUBGRAPH_URL is used as chain "polygon".
# CHAINS_JSON={"polygon":{"subgraph_url":"http://127.0.0.1:8020/subgraphs/name/cohortlens/aave-v3","rpc_url":"https://rpc.sepolia.org","cohort_oracle_address":"","cohort_registry_address":""}}
CHAINS_JSON=
ORACLE_SCAN_CHAIN=polygon
COHORT_CACHE_TTL_SECONDS=3600
PROMETHEUS_ENABLED=true
ENABLE_ZK_PROOF_FOR_ONNX=false
EZKL_BINARY=ezkl
AKASH_CLI_ENABLED=false
