# CohortLens API Environment Variables
# Copy this file to .env and fill in your values

# Database (Neon PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/cohortlens?sslmode=require

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_SECONDS=3600

# Security (Development only - set to false in production!)
FALLBACK_AUTH_ENABLED=false
DEFAULT_AUTH_USER=admin
DEFAULT_USER_PASSWORD=admin123

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# AI/ML (Optional - uses rule-based fallback if not provided)
GROQ_API_KEY=gsk_your-groq-api-key

# Feature Flags
FEATURE_FLAG_V2_ENABLED=false
FEATURE_FLAG_V2_PRIMARY=false
FEATURE_FLAG_V1_DEPRECATED=false
FEATURE_FLAG_SHADOW_MODE=false

# Server
PORT=8001
NODE_ENV=development

